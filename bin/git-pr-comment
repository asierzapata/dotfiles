#!/bin/sh
#
# Post an inline review comment on the current branch's open PR.
#
# Usage: git pr-comment <path> <line>
#
# Designed to be wired to a Zed task with $ZED_RELATIVE_FILE and $ZED_ROW so
# you can drop a line comment straight from the cursor. The line must be part
# of the PR diff, otherwise GitHub rejects it with a 422.

path="$1"
line="$2"

if [ -z "$path" ] || [ -z "$line" ]; then
  echo "usage: git pr-comment <path> <line>" >&2
  exit 1
fi

pr=$(gh pr view --json number --jq .number 2>/dev/null)
if [ -z "$pr" ]; then
  echo "No open PR found for the current branch." >&2
  exit 1
fi

printf 'Comment on %s:%s > ' "$path" "$line"
read -r body
[ -z "$body" ] && { echo "Aborted: empty comment." >&2; exit 1; }

gh api "repos/{owner}/{repo}/pulls/$pr/comments" \
  -f body="$body" \
  -f commit_id="$(git rev-parse HEAD)" \
  -f path="$path" \
  -F line="$line" \
  -f side=RIGHT
